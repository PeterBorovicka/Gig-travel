# Stripe secret key for payment processing (get from https://dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# OpenAI API key for the AI Travel Assistant (get from https://platform.openai.com/api-keys)
# Model used: gpt-4o-mini (~$5.50/month at 500 requests/day — see docs/llm-cost-analysis.md)
OPENAI_API_KEY=sk-your_openai_key_here

# Server port
PORT=3001

# Database file path (defaults to server/gig_travel.sqlite)
# DB_PATH=./gig_travel.sqlite
